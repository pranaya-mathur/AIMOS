{
  "1": {
    "inputs": {
      "ckpt_name": "juggernautXL_v9RdPhoto2Lightning.safetensors"
    },
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Load Juggernaut XL"}
  },
  "2": {
    "inputs": {
      "text": "POSITIVE_PROMPT_PLACEHOLDER",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"}
  },
  "3": {
    "inputs": {
      "text": "NEGATIVE_PROMPT_PLACEHOLDER",
      "clip": ["1", 1]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"}
  },
  "4": {
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 1
    },
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Latent Image (1024x1024)"}
  },
  "5": {
    "inputs": {
      "seed": 42,
      "steps": 6,
      "cfg": 2.0,
      "sampler_name": "dpmpp_sde",
      "scheduler": "karras",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    },
    "class_type": "KSampler",
    "_meta": {"title": "KSampler (Lightning 6-step)"}
  },
  "6": {
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "7": {
    "inputs": {
      "filename_prefix": "AIMOS_IMG",
      "images": ["6", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  }
