# AIMOS — copy to `.env` and adjust. Validated by: python3 scripts/validate_env.py
# Docker Compose: use hostnames `db` (Postgres) and `redis` (Redis) as below.

OPENAI_API_KEY=your_key_here
# Docker Compose maps Postgres/Redis to localhost (see docker-compose.yml ports). Use user/password from the `db` service.
# Containers (api/worker/beat) get DATABASE_URL/REDIS_URL overridden to hostnames `db` and `redis`.
DATABASE_URL=postgresql://user:password@localhost:5432/aimos
REDIS_URL=redis://localhost:6380/0
LOG_LEVEL=INFO

# Auth (JWT). Generate a long random string for production.
JWT_SECRET=change_me_to_a_long_random_string

# Set to 1 to skip JWT on /campaign, /agents, /launch, /creatives (local only).
# AUTH_DISABLED=

# Stripe (optional; required for billing endpoints)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# One-time payment Price ID for POST /billing/checkout/session (unless you pass price_id in body)
# STRIPE_DEFAULT_PRICE_ID=price_xxxxx
# Recurring subscription Price IDs (Professional, Growth, Enterprise)
# STRIPE_PRICE_PROFESSIONAL=price_professional_499
# STRIPE_PRICE_GROWTH=price_growth_999
# STRIPE_PRICE_ENTERPRISE=price_enterprise_custom

# Bubble / browser clients: comma-separated origins for CORS (e.g. https://yourapp.bubbleapps.io)
# CORS_ORIGINS=

# Optional: public API URL so OpenAPI schema lists correct server (Bubble API Connector)
# PUBLIC_API_BASE_URL=https://api.yourdomain.com

# --- Per-user defaults (UTC month). Set to -1 for unlimited. Admins: platform_admin role bypasses quotas.
# DEFAULT_MONTHLY_CAMPAIGN_QUOTA=50
# DEFAULT_MONTHLY_TOKEN_QUOTA=5000000
# OPENAI_INPUT_USD_PER_MILLION_TOKENS=0.15
# OPENAI_OUTPUT_USD_PER_MILLION_TOKENS=0.60

# Optional: override prompt bundle directory (Docker sets /app/prompts automatically)
# PROMPTS_DIR=
ADCREATIVE_API_KEY=
ADCREATIVE_BASE_URL=https://api.adcreative.ai
PICTORY_API_KEY=
PICTORY_BASE_URL=https://api.pictory.ai
ELEVENLABS_API_KEY=
ELEVENLABS_BASE_URL=https://api.elevenlabs.io
MEDIA_WEBHOOK_TOKEN=
ADCREATIVE_WEBHOOK_SECRET=
PICTORY_WEBHOOK_SECRET=
ELEVENLABS_WEBHOOK_SECRET=

# Set to 1 for local E2E without calling real AdCreative/Pictory/ElevenLabs APIs (api + worker).
MOCK_MEDIA_PROVIDER=
# Set to 1 to generate random performance data for optimization_tick
MOCK_METRICS=

# --- Launch integrations (optional) ---
# Meta Marketing API (Graph): POST /launch/meta
# META_ACCESS_TOKEN=
# META_AD_ACCOUNT_ID=1234567890
# META_GRAPH_VERSION=v21.0

# WhatsApp Cloud API: POST /launch/whatsapp (uses META_GRAPH_VERSION for graph.facebook.com)
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=aimos-default-verify-token
MOCK_WHATSAPP=1

# Google Ads SDK (official google-ads library): POST /launch/google
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
MOCK_GOOGLE_ADS=1

# X (Twitter) SDK (tweepy): POST /launch/social
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
MOCK_X_API=1

# SendGrid SDK (email): POST /launch/email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
MOCK_SENDGRID=1

# Twilio SDK (sms): POST /launch/sms
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
MOCK_TWILIO=1

